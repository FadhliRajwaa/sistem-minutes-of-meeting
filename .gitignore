# Environment
.env

# Vendor dependencies
/vendor/

# Writable directory (logs, cache, sessions)
/writable/cache/*
/writable/logs/*
/writable/session/*
/writable/debugbar/*
/writable/uploads/*
!/writable/cache/.gitkeep
!/writable/logs/.gitkeep
!/writable/session/.gitkeep

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Composer
composer.lock

# Test files
/test_*.php
/phpunit.xml
/.phpunit.result.cache
/phpunit.xml.dist

# Build
/build/
/node_modules/

# Temporary files
*.tmp
*.bak
*.log

# Migration helper scripts (not needed in production)
/manual_migrate.php
/verify_tables.php
/hash.php

# System framework (if using as project, not framework dev)
# /system/

# Uploads (user-generated content)
/public/uploads/*
!/public/uploads/.gitkeep
